# Local tooling / editor context (may hold personal info)
# -----------------------------------------------------------------------
.claude/
CLAUDE.md
AGENTS.md

# Local outreach/press kit, not part of the public repo
OUTREACH.md

# Raw screenshot-tour output (curated copies live in docs/)
docs/_shots/

