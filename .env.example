TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
PLEX_MEDIA_SERVER_PATH=C:\Program Files\Plex\Plex Media Server\Plex Media Server.exe
PLEX_SERVER_URL=http://127.0.0.1:32400
PLEX_TOKEN=
PLEX_CLIENT_IDENTIFIER=
PLEX_VERIFY_SSL=false
PLEX_REQUEST_TIMEOUT_SECONDS=10
PLEX_HISTORY_FETCH_LIMIT=200
ADMIN_STATUS_REFRESH_SECONDS=15
APP_DB_PATH=plex_reset_button.db
PLEX_LIBRARY_PATHS=D:\Media\Movies;D:\Media\TV
LIBRARY_INDEX_EXTENSIONS=.mkv;.mp4;.avi;.mov;.wmv;.m4v;.mpg;.mpeg;.ts;.m2ts;.iso
LIBRARY_SEARCH_RESULT_LIMIT=25

# How long (seconds) to wait before each "did Plex exit?" check
PLEX_EXIT_WAIT=2

# How long (seconds) to wait after clicking the taskbar icon before reporting success
PLEX_LAUNCH_WAIT=3

# How many times to check/retry before giving up
MAX_EXIT_RETRIES=3

# Icon matching confidence (0.0-1.0). Lower = more lenient but more false positives.
TRAY_ICON_CONFIDENCE=0.85
TASKBAR_ICON_CONFIDENCE=0.85

# =============================================================================
# MEDIA REQUEST LOOKUP — External database API keys
# =============================================================================

# TMDB (The Movie Database) — used for movie and TV show lookup
# Get a FREE read-access API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# TVDB (The TV Database) — used for TV show lookup (primary over TMDB for shows)
# Get a FREE API key at: https://thetvdb.com/api-information  (sign up → API Keys tab)
TVDB_API_KEY=

# Google Gemini — used for fuzzy title matching and 'Other' request categorization
# Get a FREE key at: https://aistudio.google.com/app/apikey
# Recommended model: gemini-2.0-flash  (fast, cheap, great for structured tasks)
# If you want a preview model, try: gemini-2.5-flash-preview-05-20
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# AniDB client name — for xAnime title lookup via AniDB's public title dump
# Default value works fine for personal use. For a registered client:
# Register free at: https://anidb.net/software/add
ANIDB_CLIENT=plexrequestbot
ANIDB_CLIENT_VER=1

# Hour of day (0-23) at which the daily library check runs
# The check scans open requests against your Plex library and marks found items
LIBRARY_CHECK_HOUR=3
