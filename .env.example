TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Telegram user IDs (comma-separated) that are ALWAYS allowed to use the bot.
# The bot also keeps a SQLite allowlist seeded from past requesters; denied
# users are shown their numeric ID so you can paste it here.
TELEGRAM_ALLOWED_USER_IDS=
PLEX_MEDIA_SERVER_PATH=C:\Program Files\Plex\Plex Media Server\Plex Media Server.exe
PLEX_SERVER_URL=http://127.0.0.1:32400
PLEX_TOKEN=
PLEX_CLIENT_IDENTIFIER=
PLEX_VERIFY_SSL=false
PLEX_REQUEST_TIMEOUT_SECONDS=10
PLEX_HISTORY_FETCH_LIMIT=200
ADMIN_STATUS_REFRESH_SECONDS=15
APP_DB_PATH=plex_reset_button.db
PLEX_LIBRARY_PATHS=D:\Media\Movies;D:\Media\TV
LIBRARY_INDEX_EXTENSIONS=.mkv;.mp4;.avi;.mov;.wmv;.m4v;.mpg;.mpeg;.ts;.m2ts;.iso
LIBRARY_SEARCH_RESULT_LIMIT=25

# How long (seconds) to wait before each "did Plex exit?" check during a hard reset
PLEX_EXIT_WAIT=2

# How long (seconds) to wait after launching Plex before reporting success
PLEX_LAUNCH_WAIT=3

# How many times to check/retry before giving up
MAX_EXIT_RETRIES=3

# Show the Hard Reset button/command in the Telegram bot (off by default —
# remote users force-killing Plex mid-stream is not for every household)
TELEGRAM_HARD_RESET_ENABLED=false

# Preferred download size per media type, in MB per minute of runtime.
# Default 10 ≈ 1.2 GB per 2h movie ≈ 300 MB per 30-min episode.
SIZE_PREF_MB_PER_MIN_MOVIE=10
SIZE_PREF_MB_PER_MIN_TV=10
SIZE_PREF_MB_PER_MIN_ANIME=10
SIZE_PREF_MB_PER_MIN_XANIME=10

# Hard ceiling (same units, 0 = no cap) — auto-grab never exceeds this.
SIZE_MAX_MB_PER_MIN_MOVIE=0
SIZE_MAX_MB_PER_MIN_TV=0
SIZE_MAX_MB_PER_MIN_ANIME=0
SIZE_MAX_MB_PER_MIN_XANIME=0

# Never auto-download cam/telesync movie releases
BLOCK_CAMS=true

# Library tab: movies under this MB/min count as "low quality"
LOW_QUALITY_MB_PER_MIN=5

# Subtitle language for the Library tab's Find Subtitles (ISO 639-1)
SUBTITLE_LANGUAGE=en

# Which Plex account is you — powers the Watchlist/Recs tab
PLEX_ACCOUNT_NAME=

# =============================================================================
# MEDIA REQUEST LOOKUP — External database API keys
# =============================================================================

# TMDB (The Movie Database) — used for movie and TV show lookup
# Get a FREE read-access API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# TVDB (The TV Database) — used for TV show lookup (primary over TMDB for shows)
# Get a FREE API key at: https://thetvdb.com/api-information  (sign up → API Keys tab)
TVDB_API_KEY=

# OMDB (IMDB-backed) — optional fallback movie DB for corrections
# Free key at: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# Ollama — used for fuzzy title matching and 'Other' request categorization.
# Default gemma3:1b (~815 MB) runs on CPU or 1 GB VRAM without hurting the
# machine. Ladder: qwen2.5:0.5b (ultra-light) < gemma3:1b < llama3.2:3b <
# ":cloud" tags (no local load, but need a free ollama.com account +
# `ollama signin`, and request text leaves this machine).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# AniDB client name — for xAnime title lookup via AniDB's public title dump
# Default value works fine for personal use. For a registered client:
# Register free at: https://anidb.net/software/add
ANIDB_CLIENT=plexrequestbot
ANIDB_CLIENT_VER=1

# Hour of day (0-23) at which the daily library check runs
# The check scans open requests against your Plex library and marks found items
LIBRARY_CHECK_HOUR=3

# =============================================================================
# TORRENT DOWNLOAD PIPELINE (needs Node.js 20+ on PATH; runner in torrent_runner/)
# =============================================================================

# Staging folder — all torrents download here first; files move to library
# folders only on a confident route with move enabled (or Apply Route click)
TORRENT_DOWNLOAD_DIR=

# Defaults for the Downloads-tab checkboxes (persisted when toggled in-app)
TORRENT_AUTO_RENAME=false
TORRENT_AUTO_MOVE=false
TORRENT_AUTO_GRAB=false

# Abort a download when no data arrives for this many seconds
TORRENT_STALL_TIMEOUT_SECONDS=900

# Built-in engine: run at most this many downloads at once (rest queue);
# a download with no progress for the rotate window gets requeued when
# something else is waiting
MAX_ACTIVE_DOWNLOADS=4
DOWNLOAD_SLOW_ROTATE_MINUTES=10

# Where NEW content lands. Blank = the library root (of the right type) on
# the drive with the most free space. Set a folder or drive root to hard-pin.
DOWNLOAD_ROOT_OVERRIDE=

# Optional: delegate downloads to a running qBittorrent (Web UI must be on)
QBITTORRENT_ENABLED=false
QBITTORRENT_URL=http://127.0.0.1:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=

# Hover tooltips on buttons
TOOLTIPS_ENABLED=true

# Overnight pre-cache: once a day (from this hour, when no downloads are
# active) quietly refresh every expensive scan so tools open instantly
IDLE_CACHE_ENABLED=true
IDLE_CACHE_HOUR=4

# Shows auto-grab (full Sonarr-style loop): automatically search + download
# missing episodes of tracked shows; rename+move are forced on for these
SHOWS_AUTO_GRAB=false
SHOWS_GRAB_LIMIT_PER_PASS=8
SHOWS_SYNC_MAX_AGE_HOURS=12
